{
  "name": "voicenexus-mobile-ai-phone-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A mobile-controlled, multilingual, real-time AI phone agent research platform.",
  "license": "UNLICENSED",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=11.0.0 <12.0.0"
  },
  "workspaces": [
