GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3300
GATEWAY_BEARER_TOKEN=replace-with-the-same-value-as-api-telephony-http-token

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-me
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_VALIDATE_SIGNATURES=false

PUBLIC_BASE_URL=https://replace-with-your-cloudflare-or-ngrok-url

# Three minutes protects trial balance while allowing a real multilingual test.
MAX_CALL_SECONDS=180

WELCOME_GREETING=Hello, this is VoiceNexus, an AI assistant calling regarding your request. Is now a good time to talk?

GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-3.1-flash-lite

