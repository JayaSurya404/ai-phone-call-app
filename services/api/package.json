{
  "name": "@voicenexus/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify control-plane API for the VoiceNexus mobile AI phone agent.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=11.0.0 <12.0.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx watch src/server.ts",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "tsx --test",
    "check": "npm run prisma:validate && npm run lint && npm run typecheck && npm run test && npm run build",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:status": "prisma migrate status",
    "db:smoke": "tsx scripts/database-smoke.ts",
    "pretypecheck": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "prisma:deploy": "prisma migrate deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.10",
    "eslint": "^9.39.5",
    "globals": "^14.0.0",
    "prisma": "^7.9.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/websocket": "^11.3.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "pg": "^8.22.0",
    "redis": "^6.1.0"
  }
}
