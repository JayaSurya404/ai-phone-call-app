# Runtime environment
NODE_ENV=development

# Fastify HTTP server
API_HOST=0.0.0.0
API_PORT=3000

# Fastify/Pino log level
LOG_LEVEL=debug

# Dependency health-check timeout
DEPENDENCY_TIMEOUT_MS=2000

# PostgreSQL
DATABASE_URL=postgresql://voicenexus:replace_with_local_postgres_password@127.0.0.1:5433/voicenexus

# Redis
REDIS_URL=redis://:replace_with_local_redis_password@127.0.0.1:6380