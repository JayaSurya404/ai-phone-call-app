POSTGRES_DB=voicenexus
POSTGRES_USER=voicenexus
POSTGRES_PASSWORD=replace_with_a_long_random_postgres_password
REDIS_PASSWORD=replace_with_a_long_random_redis_password
API_PUBLIC_PORT=3000
LOG_LEVEL=info
DEPENDENCY_TIMEOUT_MS=5000
INTERNAL_API_TOKEN=replace_with_a_long_random_internal_api_token
TELEPHONY_PROVIDER_MODE=simulator
TELEPHONY_SIMULATOR_TOKEN=replace_with_a_long_random_simulator_token
TELEPHONY_HTTP_URL=https://your-telephony-gateway.example.com
TELEPHONY_HTTP_TOKEN=replace_with_your_gateway_token
TELEPHONY_HTTP_PROVIDER_NAME=your-provider-name
TELEPHONY_WEBHOOK_PUBLIC_URL=https://api.example.com/api/v1/webhooks/telephony/events
TELEPHONY_WEBHOOK_SECRET=replace_with_a_long_random_webhook_secret
TELEPHONY_WEBHOOK_MAX_AGE_SECONDS=300
TELEPHONY_TIMEOUT_MS=5000
SCENARIO_SPEED_MULTIPLIER=1
ACTIVE_CALL_TTL_SECONDS=86400
AI_PROVIDER_MODE=simulated
INFERENCE_BASE_URL=https://your-inference-gateway.example.com
INFERENCE_INTERNAL_TOKEN=replace_with_a_long_random_inference_token
INFERENCE_TIMEOUT_MS=15000
STT_PROVIDER_NAME=faster-whisper
LLM_PROVIDER_NAME=qwen
TTS_PROVIDER_NAME=kokoro
REALTIME_CLIENT_TOKEN=replace_with_a_long_random_realtime_token
REALTIME_HEARTBEAT_MS=15000
REALTIME_CHANNEL_PREFIX=voicenexus:call-events
CORS_ORIGINS=https://your-mobile-web-origin.example.com
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000
BODY_LIMIT_BYTES=1048576
TRUST_PROXY=true